{
  "expo": {
    "name": "FlexMe",
    "slug": "FlexMe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flexme",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A14",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flexme.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FlexMe needs camera access to snap your face for photorealistic generations.",
        "NSPhotoLibraryUsageDescription": "FlexMe needs photo library access to select face photos and save generated images.",
        "NSPhotoLibraryAddUsageDescription": "FlexMe saves your generated photos to your photo library."
      }
    },
    "android": {
      "package": "com.flexme.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A14",
          "dark": {
            "backgroundColor": "#0A0A14"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FlexMe needs camera access to snap your face for photorealistic generations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FlexMe needs photo library access to select face photos and save generated images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
